		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.57.1",
		"@vitest/coverage-v8": "^3.2.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"jsdom": "^29.0.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
